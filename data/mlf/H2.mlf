default:
  atom:
    vdw_scale: 0.8
  bond:
    bond_gap_mm: 0.1
    holes:
      hole_radius_mm: 3.525
      hole_length_mm: 2.0
      bond_gap_mm: 0.0
    bond_marker: hetero-only-except-ch
    bond_marker_size_mm: 1.5
    bond_marker_depth_mm: 0.5
molecule:
  name: H2
  scale: 10.0
  atoms:
  - name: H_1
    position: [0.0099, 0.1899, 0.0]
  - name: H_2
    position: [-0.7301, 0.1899, 0.0]
  bonds:
  - atom_pair: [H_1, H_2]
    bond_type: spin
