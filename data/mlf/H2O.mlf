default:
  atom:
    vdw_scale: 0.8
  bond:
    bond_gap_mm: 0.1
    bond_marker: hetero-only-except-ch
    bond_marker_size_mm: 1.5
    bond_marker_depth_mm: 0.5
molecule:
  name: H2O
  scale: 10.0
  atoms:
  - name: O_1
    position: [0.1325, 0.3341, 0.0044]
  - name: H_2
    position: [1.0925, 0.3341, 0.0044]
  - name: H_3
    position: [-0.188, 1.239, 0.0044]
  bonds:
  - atom_pair: [O_1, H_2]
    bond_type: spin
  - atom_pair: [O_1, H_3]
    bond_type: spin
